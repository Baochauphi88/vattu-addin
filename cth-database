<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>CTH Database</title>
<style>
/* ============================================================
   RESET & VARIABLES
============================================================ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#1a73e8;--blue-d:#1557b0;--blue-bg:#e8f0fe;
  --green:#1e8e3e;--red:#d93025;--red-bg:#fce8e6;
  --bg:#f1f3f4;--surface:#fff;--border:#dadce0;
  --text:#202124;--sub:#5f6368;--row-alt:#f8f9fa;
  --shadow:0 1px 3px rgba(0,0,0,.12),0 1px 2px rgba(0,0,0,.08);
  --r:8px;
}
body{font-family:'Segoe UI',Roboto,Arial,sans-serif;font-size:13px;
     color:var(--text);background:var(--bg);height:100vh;
     overflow:hidden;display:flex;flex-direction:column}

/* ============================================================
   SCREENS
============================================================ */
.screen{display:none;flex-direction:column;height:100vh}
.screen.active{display:flex}

/* ============================================================
   SETUP SCREEN
============================================================ */
#setupScreen{align-items:center;justify-content:center;
             background:linear-gradient(135deg,#1a73e8,#0d47a1)}
.setup-card{background:var(--surface);border-radius:16px;
            padding:36px 32px;width:420px;max-width:95vw;
            box-shadow:0 8px 32px rgba(0,0,0,.24)}
.setup-logo{text-align:center;margin-bottom:24px}
.setup-logo .ico{font-size:36px}
.setup-logo h2{font-size:20px;font-weight:700;color:var(--blue);margin:6px 0 2px}
.setup-logo p{font-size:11px;color:var(--sub)}
.field-label{font-size:11px;font-weight:600;color:var(--sub);
             text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px;display:block}
.field-input{width:100%;padding:9px 12px;border:1.5px solid var(--border);
             border-radius:var(--r);font-size:13px;outline:none;
             transition:border-color .2s;font-family:inherit}
.field-input:focus{border-color:var(--blue)}
.field-group{margin-bottom:14px}
.btn-primary{width:100%;padding:11px;background:var(--blue);color:#fff;
             border:none;border-radius:var(--r);font-size:14px;font-weight:600;
             cursor:pointer;transition:background .2s;font-family:inherit}
.btn-primary:hover{background:var(--blue-d)}
.btn-primary:disabled{background:#9ab4d8;cursor:not-allowed}
.msg-error{color:var(--red);font-size:12px;text-align:center;
           min-height:18px;margin-top:8px}
.msg-ok{color:var(--green);font-size:12px;text-align:center;margin-top:8px}
.setup-hint{font-size:11px;color:var(--sub);margin-top:6px;line-height:1.5}
.setup-hint code{background:#f1f3f4;padding:1px 5px;border-radius:3px;
                 font-size:10px;word-break:break-all}

/* ============================================================
   LOGIN SCREEN
============================================================ */
#loginScreen{align-items:center;justify-content:center;
             background:linear-gradient(135deg,#1a73e8,#0d47a1)}
.login-card{background:var(--surface);border-radius:16px;
            padding:36px 32px;width:360px;max-width:95vw;
            box-shadow:0 8px 32px rgba(0,0,0,.24)}
.login-logo{text-align:center;margin-bottom:24px}
.login-logo .ico{font-size:40px}
.login-logo h2{font-size:22px;font-weight:700;color:var(--blue);margin:6px 0 2px}
.login-logo p{font-size:12px;color:var(--sub)}
.remember-row{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.remember-row label{font-size:12px;color:var(--sub);cursor:pointer}

/* ============================================================
   MAIN APP
============================================================ */
#appScreen{flex-direction:column}

/* TOPBAR */
.topbar{background:var(--blue);color:#fff;padding:0 14px;
        display:flex;align-items:center;justify-content:space-between;
        height:46px;flex-shrink:0;box-shadow:var(--shadow);z-index:200}
.topbar-left{display:flex;align-items:center;gap:10px}
.topbar-logo{font-size:15px;font-weight:700;letter-spacing:.3px}
.topbar-badge{background:rgba(255,255,255,.2);border-radius:4px;
              padding:2px 7px;font-size:11px}
.topbar-right{display:flex;align-items:center;gap:8px;font-size:12px}
.topbar-user{opacity:.9;max-width:240px;overflow:hidden;
             text-overflow:ellipsis;white-space:nowrap}
.btn-topbar{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);
            color:#fff;padding:4px 10px;border-radius:4px;cursor:pointer;
            font-size:11px;font-family:inherit;transition:background .2s}
.btn-topbar:hover{background:rgba(255,255,255,.25)}

/* NAV TABS */
.nav-tabs{background:var(--surface);border-bottom:2px solid var(--border);
          display:flex;flex-shrink:0;overflow-x:auto;scrollbar-width:none;
          position:relative;z-index:100}
.nav-tabs::-webkit-scrollbar{display:none}
.nav-tab{padding:10px 16px;border:none;background:none;cursor:pointer;
         font-size:13px;font-weight:500;color:var(--sub);white-space:nowrap;
         border-bottom:2.5px solid transparent;margin-bottom:-2px;
         transition:color .15s,border-color .15s;font-family:inherit}
.nav-tab:hover{color:var(--blue)}
.nav-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
.nav-tab-setup{margin-left:auto;color:var(--sub)}

/* CONTENT AREA */
.content-area{flex:1;overflow:hidden;display:flex;position:relative}

/* ============================================================
   SHEET PANEL
============================================================ */
.sheet-panel{display:none;flex-direction:column;flex:1;overflow:hidden;min-width:0}
.sheet-panel.active{display:flex}

/* SEARCH BAR */
.search-bar{padding:8px 12px;background:var(--surface);
            border-bottom:1px solid var(--border);flex-shrink:0;
            display:flex;gap:8px;align-items:center}
.search-wrap{flex:1;display:flex;align-items:center;
             border:1.5px solid var(--border);border-radius:20px;
             padding:0 10px;background:var(--bg);
             transition:border-color .2s,box-shadow .2s}
.search-wrap:focus-within{border-color:var(--blue);
                           box-shadow:0 0 0 2px rgba(26,115,232,.15)}
.search-wrap input{border:none;background:none;outline:none;
                   padding:7px 6px;flex:1;font-size:13px;font-family:inherit}
.ico-search{color:var(--sub);font-size:14px}
.btn-x{background:none;border:none;cursor:pointer;color:var(--sub);
       font-size:14px;display:none;padding:2px;line-height:1}

/* PRESET BAR */
.preset-bar{padding:5px 12px;background:#f0f4ff;border-bottom:1px solid #c5d5f5;
            display:flex;align-items:center;gap:6px;flex-wrap:wrap;flex-shrink:0}
.preset-label{font-size:10px;font-weight:700;color:var(--sub);
              text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
.preset-chip{padding:3px 10px;border-radius:10px;font-size:11px;font-weight:500;
             border:1.5px solid var(--border);background:var(--surface);
             cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:3px;
             font-family:inherit;white-space:nowrap}
.preset-chip:hover{border-color:var(--blue);color:var(--blue)}
.preset-chip.on{background:var(--blue);color:#fff;border-color:var(--blue)}
.preset-chip .px{display:none;font-size:12px;opacity:.8;line-height:1;
                 margin-left:2px;cursor:pointer}
.preset-chip:hover .px{display:inline}
.btn-add-preset{padding:3px 9px;border-radius:10px;font-size:11px;
                border:1.5px dashed var(--blue);color:var(--blue);
                background:none;cursor:pointer;font-family:inherit;white-space:nowrap}

/* INFO BAR */
.info-bar{padding:3px 12px;font-size:11px;color:var(--sub);
          background:var(--surface);border-bottom:1px solid var(--border);
          flex-shrink:0;display:flex;align-items:center;justify-content:space-between;
          min-height:24px}
.info-sel{color:var(--blue);font-weight:600}

/* LIST + DETAIL SPLIT */
.split{flex:1;display:flex;overflow:hidden;min-height:0}

/* CARD LIST */
.card-list{flex:1;overflow-y:auto;padding:6px;min-width:0;
           scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.card-list::-webkit-scrollbar{width:6px}
.card-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

.card-item{background:var(--surface);border:1.5px solid var(--border);
           border-radius:var(--r);padding:9px 12px;margin-bottom:5px;
           cursor:pointer;transition:border-color .15s,box-shadow .15s;
           display:flex;align-items:flex-start;gap:10px;user-select:none}
.card-item:hover{border-color:#aac4f5;box-shadow:0 1px 6px rgba(26,115,232,.12)}
.card-item.selected{border-color:var(--blue);background:var(--blue-bg);
                    box-shadow:0 0 0 1.5px var(--blue)}
.card-cb{width:16px;height:16px;flex-shrink:0;margin-top:2px;cursor:pointer;accent-color:var(--blue)}
.card-body{flex:1;min-width:0}
.card-title{font-size:13px;font-weight:600;color:var(--blue);margin-bottom:3px;
            white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card-meta{display:flex;flex-wrap:wrap;gap:4px 10px}
.card-tag{font-size:11px;color:var(--sub);display:flex;align-items:center;gap:3px}
.card-tag b{color:var(--text);font-weight:500}
.badge{display:inline-block;padding:1px 7px;border-radius:8px;font-size:10px;
       font-weight:600;background:#e8f5e9;color:#1e8e3e}
.badge.red{background:#fce8e6;color:var(--red)}
.badge.blue{background:var(--blue-bg);color:var(--blue)}
.badge.gray{background:var(--row-alt);color:var(--sub)}

/* DETAIL PANEL */
.detail-panel{width:300px;min-width:260px;max-width:380px;
              background:var(--surface);border-left:1px solid var(--border);
              display:flex;flex-direction:column;flex-shrink:0;
              transition:width .2s;overflow:hidden}
.detail-panel.hidden{width:0;min-width:0;border:none}
.detail-header{padding:10px 12px;background:var(--blue);color:#fff;
               display:flex;align-items:center;justify-content:space-between;
               flex-shrink:0}
.detail-title{font-size:13px;font-weight:600;white-space:nowrap;
              overflow:hidden;text-overflow:ellipsis;flex:1;margin-right:8px}
.btn-close-detail{background:none;border:none;color:#fff;cursor:pointer;
                  font-size:18px;line-height:1;opacity:.8;padding:2px}
.btn-close-detail:hover{opacity:1}
.detail-body{flex:1;overflow-y:auto;padding:8px;
             scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.detail-body::-webkit-scrollbar{width:5px}
.detail-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.detail-row{display:flex;align-items:baseline;padding:5px 4px;
            border-bottom:1px solid #f1f3f4;gap:6px}
.detail-row:last-child{border-bottom:none}
.detail-key{font-size:11px;color:var(--sub);min-width:80px;flex-shrink:0;font-weight:500}
.detail-val{font-size:12px;color:var(--text);flex:1;word-break:break-word;
            line-height:1.4}
.detail-val.empty{color:#bbb;font-style:italic}
.btn-copy-field{background:none;border:1px solid var(--border);color:var(--sub);
                padding:1px 7px;border-radius:4px;font-size:10px;cursor:pointer;
                transition:all .15s;flex-shrink:0;font-family:inherit}
.btn-copy-field:hover{border-color:var(--blue);color:var(--blue)}

/* PRESET COPY SECTION */
.detail-section{margin-top:8px}
.detail-section-title{font-size:10px;font-weight:700;color:var(--sub);
                      text-transform:uppercase;letter-spacing:.5px;
                      padding:4px 4px 2px;border-bottom:1px solid var(--border);
                      margin-bottom:4px}
.preset-copy-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;padding:4px}
.btn-preset-copy{padding:5px 6px;border:1.5px solid var(--border);border-radius:var(--r);
                 background:var(--surface);cursor:pointer;font-size:11px;font-weight:500;
                 text-align:left;transition:all .15s;font-family:inherit;color:var(--text)}
.btn-preset-copy:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-bg)}
.btn-preset-copy .pcn{font-size:11px;font-weight:600;display:block}
.btn-preset-copy .pcc{font-size:9px;color:var(--sub);display:block;
                      white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* COPY ALL BUTTON */
.detail-footer{padding:8px;flex-shrink:0;border-top:1px solid var(--border)}
.btn-copy-all{width:100%;padding:9px;background:var(--green);color:#fff;
              border:none;border-radius:var(--r);font-size:13px;font-weight:600;
              cursor:pointer;transition:background .2s;font-family:inherit;
              display:flex;align-items:center;justify-content:center;gap:6px}
.btn-copy-all:hover{background:#1a7a36}

/* ============================================================
   SETUP TAB PANEL
============================================================ */
.setup-panel{display:none;flex-direction:column;flex:1;overflow:hidden}
.setup-panel.active{display:flex}
.setup-scroll{flex:1;overflow-y:auto;padding:16px;
              scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.setup-section{background:var(--surface);border-radius:var(--r);
               border:1px solid var(--border);padding:16px;margin-bottom:14px}
.setup-section-title{font-size:13px;font-weight:700;color:var(--text);
                     margin-bottom:12px;display:flex;align-items:center;gap:6px}
.preset-list-item{display:flex;align-items:center;padding:8px 10px;
                  border:1px solid var(--border);border-radius:var(--r);
                  margin-bottom:6px;cursor:pointer;transition:background .15s;
                  gap:8px;background:var(--surface)}
.preset-list-item:hover{background:var(--bg)}
.preset-list-item .pn{font-size:13px;font-weight:600;flex:1}
.preset-list-item .pc{font-size:11px;color:var(--sub);flex:2}
.preset-list-item .pd{background:none;border:1px solid var(--border);color:var(--red);
                      padding:3px 8px;border-radius:4px;cursor:pointer;font-size:11px;
                      font-family:inherit}
.preset-list-item .pd:hover{background:var(--red-bg)}
.btn-add-preset-setup{padding:7px 14px;border:1.5px dashed var(--blue);border-radius:var(--r);
                      color:var(--blue);background:none;cursor:pointer;font-size:12px;
                      font-weight:600;font-family:inherit}

/* Change password */
.cpw-form{display:flex;flex-direction:column;gap:10px}

/* ============================================================
   MODAL
============================================================ */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);
          z-index:1000;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--surface);border-radius:12px;padding:22px;
       width:460px;max-width:96vw;box-shadow:0 8px 32px rgba(0,0,0,.24)}
.modal-title{font-size:15px;font-weight:700;margin-bottom:14px}
.modal-footer{display:flex;justify-content:flex-end;gap:8px;margin-top:18px}
.btn-sm{padding:7px 14px;border:1px solid var(--border);border-radius:var(--r);
        background:var(--surface);cursor:pointer;font-size:12px;font-weight:600;
        font-family:inherit;transition:all .15s}
.btn-sm:hover{background:var(--bg)}
.btn-sm.blue{background:var(--blue);color:#fff;border-color:var(--blue)}
.btn-sm.blue:hover{background:var(--blue-d)}
.btn-sm.red{color:var(--red);border-color:var(--red)}
.btn-sm.red:hover{background:var(--red-bg)}

/* col picker */
.col-picker{display:flex;flex-wrap:wrap;gap:5px;max-height:160px;overflow-y:auto;
            border:1px solid var(--border);border-radius:var(--r);padding:8px;margin-bottom:8px}
.cp-chip{padding:3px 9px;border-radius:10px;font-size:11px;
         border:1.5px solid var(--border);cursor:pointer;user-select:none;
         transition:all .15s;font-family:inherit}
.cp-chip.on{background:var(--blue);color:#fff;border-color:var(--blue)}
.col-order{display:flex;flex-wrap:wrap;gap:5px;min-height:32px;
           border:1px dashed var(--border);border-radius:var(--r);padding:6px}
.co-chip{padding:3px 9px;border-radius:10px;font-size:11px;background:var(--blue);
         color:#fff;cursor:grab;display:flex;align-items:center;gap:3px;user-select:none}
.co-chip .rx{cursor:pointer;opacity:.75;font-size:12px}

/* ============================================================
   TOAST
============================================================ */
#toast{position:fixed;bottom:22px;left:50%;
       transform:translateX(-50%) translateY(70px);
       background:#323232;color:#fff;padding:9px 18px;border-radius:8px;
       font-size:13px;z-index:9999;transition:transform .28s ease;
       pointer-events:none;white-space:nowrap;max-width:90vw;text-align:center}
#toast.show{transform:translateX(-50%) translateY(0)}

/* ============================================================
   LOADING OVERLAY
============================================================ */
#loadOverlay{position:fixed;inset:0;background:rgba(255,255,255,.85);
             z-index:500;display:none;align-items:center;justify-content:center;
             flex-direction:column;gap:12px}
#loadOverlay.show{display:flex}
.spinner{width:36px;height:36px;border:3px solid var(--border);
         border-top-color:var(--blue);border-radius:50%;
         animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.load-msg{font-size:13px;color:var(--sub)}

/* ============================================================
   HIGHLIGHT
============================================================ */
.hl{background:#fff176;border-radius:2px;padding:0 1px}

/* ============================================================
   RESPONSIVE
============================================================ */
@media(max-width:680px){
  .detail-panel{width:100%;position:absolute;right:0;top:0;bottom:0;
                box-shadow:-3px 0 16px rgba(0,0,0,.15)}
  .topbar-user{max-width:120px}
}
@media(max-width:400px){
  .preset-copy-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- ============================================================
     LOADING OVERLAY
============================================================ -->
<div id="loadOverlay">
  <div class="spinner"></div>
  <div class="load-msg" id="loadMsg">Đang tải...</div>
</div>

<!-- ============================================================
     SETUP SCREEN (lần đầu hoặc chưa có URL)
============================================================ -->
<div class="screen" id="setupScreen">
  <div class="setup-card">
    <div class="setup-logo">
      <div class="ico">🏗️</div>
      <h2>CTH DATABASE</h2>
      <p>Cấu hình kết nối Google Sheet</p>
    </div>
    <div class="field-group">
      <label class="field-label">Google Apps Script URL</label>
      <input class="field-input" id="gasUrl" type="url"
             placeholder="https://script.google.com/macros/s/.../exec">
      <div class="setup-hint">
        Lấy từ Apps Script → Deploy → Web App → Copy URL<br>
        <code id="urlPreview" style="display:none"></code>
      </div>
    </div>
    <button class="btn-primary" id="btnConnect" onclick="saveConfig()">🔗 Lưu & Kết nối</button>
    <div class="msg-error" id="setupError"></div>
    <div class="msg-ok"    id="setupOk"></div>
  </div>
</div>

<!-- ============================================================
     LOGIN SCREEN
============================================================ -->
<div class="screen" id="loginScreen">
  <div class="login-card">
    <div class="login-logo">
      <div class="ico">🏗️</div>
      <h2>CTH DATABASE</h2>
      <p>Đăng nhập để sử dụng</p>
    </div>
    <div class="field-group">
      <label class="field-label">Mã nhân viên</label>
      <input class="field-input" id="loginMaNV" placeholder="VD: CTH-001" autocomplete="username">
    </div>
    <div class="field-group">
      <label class="field-label">Mật khẩu</label>
      <input class="field-input" id="loginPass" type="password"
             placeholder="Nhập mật khẩu" autocomplete="current-password">
    </div>
    <div class="remember-row">
      <input type="checkbox" id="rememberMe" checked>
      <label for="rememberMe">Ghi nhớ đăng nhập</label>
    </div>
    <button class="btn-primary" id="btnLogin" onclick="doLogin()">Đăng nhập</button>
    <div class="msg-error" id="loginError"></div>
    <div style="text-align:right;margin-top:8px">
      <span style="font-size:11px;color:var(--sub);cursor:pointer;text-decoration:underline"
            onclick="showSetup()">⚙ Đổi URL kết nối</span>
    </div>
  </div>
</div>

<!-- ============================================================
     MAIN APP SCREEN
============================================================ -->
<div class="screen" id="appScreen">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <span class="topbar-logo">🏗️ CTH DB</span>
      <span class="topbar-badge" id="tbCacheTag" style="display:none">📦 Cache</span>
    </div>
    <div class="topbar-right">
      <span class="topbar-user" id="tbUser"></span>
      <button class="btn-topbar" onclick="refreshData()">🔄</button>
      <button class="btn-topbar" onclick="doLogout()">↩ Thoát</button>
    </div>
  </div>

  <!-- NAV TABS (data sheets + Setup tab) -->
  <div class="nav-tabs" id="navTabs">
    <button class="nav-tab nav-tab-setup" onclick="switchToSetup()">⚙ Setup</button>
  </div>

  <!-- CONTENT -->
  <div class="content-area" id="contentArea">
    <!-- Sheet panels injected here by JS -->

    <!-- SETUP PANEL -->
    <div class="setup-panel" id="panelSetup">
      <div class="setup-scroll">

        <!-- URL config -->
        <div class="setup-section">
          <div class="setup-section-title">🔗 Kết nối Google Sheet</div>
          <div class="field-group">
            <label class="field-label">Apps Script URL</label>
            <input class="field-input" id="cfgUrl" type="url"
                   placeholder="https://script.google.com/macros/s/.../exec">
            <div class="setup-hint">Lấy từ Apps Script → Deploy → Web App → Copy URL</div>
          </div>
          <button class="btn-primary" onclick="saveUrlFromSetup()">💾 Lưu & Kết nối lại</button>
          <div class="msg-error" id="cfgError"></div>
          <div class="msg-ok"    id="cfgOk"></div>
        </div>

        <!-- Preset management -->
        <div class="setup-section">
          <div class="setup-section-title">📋 Quản lý Preset Copy</div>
          <div style="margin-bottom:8px;font-size:11px;color:var(--sub)">
            Chọn sheet để quản lý preset:
            <select id="presetSheetSel" onchange="renderPresetList()"
