            </div>
            <div class="field-group" style="margin:0">
              <label class="field-label">Xác nhận mật khẩu mới</label>
              <input class="field-input" id="cpwConfirm" type="password">
            </div>
            <button class="btn-primary" onclick="doChangePassword()">🔑 Đổi mật khẩu</button>
            <div class="msg-error" id="cpwError"></div>
