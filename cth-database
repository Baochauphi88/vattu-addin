<!-- TOAST -->
<div id="toast"></div>

<!-- ============================================================
     JAVASCRIPT
============================================================ -->
<script>
'use strict';

// ============================================================
// STATE
// ============================================================
const S = {
  gasUrl:      '',
  user:        null,   // {maNV, hoTen, phongBan, ...}
  token:       '',
  sheets:      [],     // [{sheetName, headers, rows}]
  filtered:    {},     // sheetName → rows[]
  selected:    {},     // sheetName → Set<rowIdx>
  presets:     {},     // sheetName → {presetName:[cols]}
  activePreset:{},     // sheetName → presetName|null
  activeSheet: null,
  detailRow:   null,   // {sheetName, rowIdx}
  fetchedAt:   null,
  // preset modal state
  _pmSheet: null,
  _pmEdit:  null,
  _pmCols:  [],
  _dragIdx: null,
};

// ============================================================
// UTILS
// ============================================================
const $ = id => document.getElementById(id);
const rmAccents = s =>
  s.normalize('NFD').replace(/[\u0300-\u036f]/g,'')
   .replace(/đ/g,'d').replace(/Đ/g,'D').toLowerCase();

function matchSearch(cells, q) {
  if (!q.trim()) return true;
  const kws  = q.split('*').map(k => rmAccents(k.trim())).filter(Boolean);
  const text = rmAccents(cells.join(' '));
  return kws.every(k => text.includes(k));
}

function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function hlText(text, q) {
  if (!q.trim()) return esc(text);
  let r = esc(text);
  q.split('*').map(k=>k.trim()).filter(Boolean).forEach(k=>{
    const re = new RegExp(k.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi');
    r = r.replace(re, m=>`<span class="hl">${m}</span>`);
  });
  return r;
}

function toast(msg, dur=2400) {
  const el = $('toast');
  el.textContent = msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'), dur);
}

function loading(show, msg='Đang tải...') {
  $('loadMsg').textContent = msg;
  $('loadOverlay').classList.toggle('show', show);
}

function showScreen(id) {
  ['setupScreen','loginScreen','appScreen'].forEach(s=>{
    $(s).classList.toggle('active', s===id);
  });
}

// ============================================================
// LOCAL STORAGE HELPERS
// ============================================================
const LS = {
  get: k => { try { return JSON.parse(localStorage.getItem(k)); } catch(_){return null;} },
  set: (k,v) => localStorage.setItem(k, JSON.stringify(v)),
  del: k => localStorage.removeItem(k),
};

// ============================================================
// BOOT
// ============================================================
window.addEventListener('load', boot);

async function boot() {
  S.gasUrl  = LS.get('cth_url') || '';
  S.presets = LS.get('cth_presets') || {};

  if (!S.gasUrl) { showScreen('setupScreen'); return; }

  // Kiểm tra remember me
  const saved = LS.get('cth_user');
  if (saved?.user && saved?.token) {
    S.user  = saved.user;
    S.token = saved.token;
    await loadData();
    return;
  }

  showScreen('loginScreen');
  $('loginMaNV').focus();
}

// ============================================================
// SETUP / CONFIG
// ============================================================
function showSetup() {
  showScreen('setupScreen');
  $('gasUrl').value = S.gasUrl || '';
}

async function saveConfig() {
  const url = $('gasUrl').value.trim();
  $('setupError').textContent = '';
  $('setupOk').textContent    = '';
  if (!url || !url.startsWith('https://script.google.com')) {
    $('setupError').textContent = 'URL không hợp lệ. Phải bắt đầu bằng https://script.google.com';
    return;
  }
  $('btnConnect').disabled = true;
  $('btnConnect').textContent = '⏳ Đang kiểm tra...';
  try {
    const r = await apiFetch(url, { action:'ping' });
    if (!r.ok) throw new Error('API không phản hồi');
    S.gasUrl = url;
    LS.set('cth_url', url);
    $('setupOk').textContent = '✅ Kết nối thành công!';
    setTimeout(()=>{ showScreen('loginScreen'); $('loginMaNV').focus(); }, 800);
  } catch(e) {
    $('setupError').textContent = '❌ Lỗi kết nối: ' + e.message;
  } finally {
    $('btnConnect').disabled  = false;
    $('btnConnect').textContent = '🔗 Lưu & Kết nối';
  }
}

async function saveUrlFromSetup() {
  const url = $('cfgUrl').value.trim();
  $('cfgError').textContent = ''; $('cfgOk').textContent = '';
  if (!url || !url.startsWith('https://script.google.com')) {
    $('cfgError').textContent = 'URL không hợp lệ'; return;
  }
  try {
    loading(true,'Đang kiểm tra kết nối...');
    const r = await apiFetch(url,{action:'ping'});
    if (!r.ok) throw new Error('API không phản hồi');
    S.gasUrl = url;
    LS.set('cth_url', url);
    LS.del('cth_data'); // xóa cache cũ
    $('cfgOk').textContent = '✅ Đã lưu. Đang tải lại dữ liệu...';
    await loadData(true);
  } catch(e) {
    $('cfgError').textContent = '❌ ' + e.message;
  } finally { loading(false); }
}

// ============================================================
// API FETCH HELPER
// ============================================================
async function apiFetch(url, params) {
  const u = new URL(url);
  Object.entries(params).forEach(([k,v]) => u.searchParams.set(k,v));
  const res = await fetch(u.toString());
  if (!res.ok) throw new Error('HTTP ' + res.status);
  return res.json();
}

function apiCall(params) {
  return apiFetch(S.gasUrl, params);
}

// ============================================================
// LOGIN
// ============================================================
async function doLogin() {
  const maNV = $('loginMaNV').value.trim();
  const pass = $('loginPass').value.trim();
  $('loginError').textContent = '';
  if (!maNV || !pass) { $('loginError').textContent = 'Vui lòng nhập đầy đủ'; return; }

  $('btnLogin').disabled    = true;
  $('btnLogin').textContent = '⏳ Đang kiểm tra...';

  try {
    const r = await apiCall({ action:'login', maNV, matKhau:pass });
    if (!r.success) {
      $('loginError').textContent = r.message || 'Đăng nhập thất bại';
      return;
    }
    S.user  = r.user;
    S.token = r.token;
    if ($('rememberMe').checked) {
      LS.set('cth_user', { user: r.user, token: r.token });
    }
    await loadData();
  } catch(e) {
    $('loginError').textContent = '❌ Lỗi kết nối: ' + e.message;
  } finally {
    $('btnLogin').disabled    = false;
    $('btnLogin').textContent = 'Đăng nhập';
  }
}

function doLogout() {
  LS.del('cth_user');
  S.user = null; S.token = '';
  showScreen('loginScreen');
  $('loginMaNV').value = '';
  $('loginPass').value  = '';
  $('loginError').textContent = '';
}

// ============================================================
// LOAD DATA (cache-first)
// ============================================================
async function loadData(forceRefresh = false) {
  showScreen('appScreen');
  loading(true, 'Đang tải dữ liệu...');

  // Thử load cache trước
  const cache = LS.get('cth_data');
  if (!forceRefresh && cache?.data && cache?.fetchedAt) {
    S.sheets    = cache.data;
    S.fetchedAt = cache.fetchedAt;
    buildApp(true); // fromCache = true
    loading(false);
    // Fetch mới ở background
    fetchFresh(true);
    return;
  }

  // Không có cache → fetch ngay
  await fetchFresh(false);
  loading(false);
}

async function fetchFresh(background = false) {
  if (!background) loading(true,'Đang tải từ Google Sheet...');
  try {
    const r = await apiCall({ action:'getData', maNV: S.user.maNV, token: S.token });
    if (!r.success) {
      if (!background) toast('❌ ' + (r.message || 'Tải dữ liệu thất bại'));
      return;
    }
    S.sheets    = r.data;
    S.fetchedAt = r.fetchedAt;
    LS.set('cth_data', { data: r.data, fetchedAt: r.fetchedAt });
    buildApp(false);
    if (background) toast('🔄 Dữ liệu đã được cập nhật mới nhất');
  } catch(e) {
    if (!background) toast('❌ Lỗi: ' + e.message);
  } finally {
    if (!background) loading(false);
  }
}

async function refreshData() {
  loading(true,'Đang tải dữ liệu mới...');
  await fetchFresh(false);
  loading(false);
  toast('✅ Đã cập nhật dữ liệu');
}

function clearCacheAndReload() {
  LS.del('cth_data');
  refreshData();
}

// ============================================================
// BUILD APP UI
// ============================================================
function buildApp(fromCache) {
  // Topbar
  $('tbUser').textContent = `${S.user.hoTen} — ${S.user.phongBan}`;
  $('tbCacheTag').style.display = fromCache ? '' : 'none';

  // Reset state per sheet
  S.sheets.forEach(sh => {
    S.filtered[sh.sheetName]     = sh.rows;
    S.selected[sh.sheetName]     = new Set();
    if (!S.presets[sh.sheetName]) S.presets[sh.sheetName] = {};
    if (S.activePreset[sh.sheetName] === undefined) S.activePreset[sh.sheetName] = null;
  });

  buildTabs();
  buildPanels();

  // Populate setup panel
  $('cfgUrl').value = S.gasUrl;
  updateCacheInfo();
  populatePresetSheetSel();

  if (S.sheets.length > 0) switchTab(S.sheets[0].sheetName);
}

// ============================================================
// TABS
// ============================================================
function buildTabs() {
  const nav = $('navTabs');
  // Xóa tab sheet cũ (giữ lại tab Setup ở cuối)
  const setupBtn = nav.querySelector('.nav-tab-setup');
  nav.innerHTML = '';
  nav.appendChild(setupBtn);

  S.sheets.forEach((sh, i) => {
    const btn = document.createElement('button');
    btn.className    = 'nav-tab';
    btn.dataset.sheet = sh.sheetName;
    btn.textContent  = sh.sheetName;
    btn.onclick      = () => switchTab(sh.sheetName);
    nav.insertBefore(btn, setupBtn);
  });
}

function switchTab(sheetName) {
  S.activeSheet = sheetName;
  // nav highlight
  document.querySelectorAll('.nav-tab:not(.nav-tab-setup)').forEach(b=>{
    b.classList.toggle('active', b.dataset.sheet === sheetName);
  });
  document.querySelector('.nav-tab-setup').classList.remove('active');
  // panels
  document.querySelectorAll('.sheet-panel').forEach(p=>p.classList.remove('active'));
  $('panelSetup').classList.remove('active');
  const panel = $('panel_' + sheetName);
  if (panel) panel.classList.add('active');

  renderCards(sheetName);
  renderPresetChips(sheetName);
}

function switchToSetup() {
  S.activeSheet = null;
  document.querySelectorAll('.nav-tab:not(.nav-tab-setup)').forEach(b=>b.classList.remove('active'));
  document.querySelector('.nav-tab-setup').classList.add('active');
  document.querySelectorAll('.sheet-panel').forEach(p=>p.classList.remove('active'));
  $('panelSetup').classList.add('active');
  updateCacheInfo();
  populatePresetSheetSel();
  renderPresetList();
}

// ============================================================
// BUILD PANELS
// ============================================================
function buildPanels() {
  const area = $('contentArea');
  // Xóa panel sheet cũ
  area.querySelectorAll('.sheet-panel').forEach(p=>p.remove());

  S.sheets.forEach(sh => {
    const sn  = sh.sheetName;
    const div = document.createElement('div');
    div.className = 'sheet-panel';
    div.id        = 'panel_' + sn;
    div.innerHTML = `
      <div class="search-bar">
        <div class="search-wrap">
          <span class="ico-search">🔍</span>
          <input type="text" id="srch_${sn}"
                 placeholder="Tìm kiếm... (dùng * phân cách từ khóa)"
                 oninput="onSearch('${sn}')"
                 onkeydown="if(event.key==='Escape')clearSearch('${sn}')">
          <button class="btn-x" id="bx_${sn}" onclick="clearSearch('${sn}')">✕</button>
        </div>
        <button class="btn-sm" onclick="copySelectedRows('${sn}')">📋 Copy chọn</button>
        <button class="btn-sm" onclick="copyAll('${sn}')">📋 Copy tất cả</button>
      </div>
      <div class="preset-bar" id="pbar_${sn}">
        <span class="preset-label">PRESET:</span>
        <div id="pchips_${sn}" style="display:flex;flex-wrap:wrap;gap:5px;align-items:center"></div>
        <button class="btn-add-preset" onclick="openPresetModal('${sn}')">+ Preset</button>
      </div>
      <div class="info-bar">
        <span id="info_${sn}"></span>
        <span id="sel_${sn}" class="info-sel"></span>
      </div>
      <div class="split">
        <div class="card-list" id="clist_${sn}"></div>
        <div class="detail-panel hidden" id="dpanel_${sn}">
          <div class="detail-header">
            <span class="detail-title" id="dtitle_${sn}"></span>
            <button class="btn-close-detail" onclick="closeDetail('${sn}')">✕</button>
          </div>
          <div class="detail-body" id="dbody_${sn}"></div>
          <div class="detail-footer">
            <button class="btn-copy-all" onclick="copyDetailRow('${sn}')">
              📋 <span id="dcopyLabel_${sn}">Copy dòng này</span>
            </button>
          </div>
        </div>
      </div>`;
    area.insertBefore(div, $('panelSetup'));
  });
}

// ============================================================
// SEARCH
// ============================================================
function onSearch(sn) {
  const q   = $('srch_' + sn).value;
  const bx  = $('bx_' + sn);
  if (bx) bx.style.display = q ? 'block' : 'none';

  const sh = S.sheets.find(s=>s.sheetName===sn);
  if (!sh) return;
  S.filtered[sn] = q
    ? sh.rows.filter(r => matchSearch(r, q))
    : sh.rows;
  S.selected[sn].clear();
  renderCards(sn);
}

function clearSearch(sn) {
  const el = $('srch_' + sn);
  if (el) el.value = '';
  onSearch(sn);
}

// ============================================================
// RENDER CARDS
// ============================================================
function renderCards(sn) {
  const sh       = S.sheets.find(s=>s.sheetName===sn);
  const rows     = S.filtered[sn] || [];
  const selected = S.selected[sn];
  const q        = ($('srch_'+sn)?.value || '').trim();
  const list     = $('clist_' + sn);
  const infoEl   = $('info_' + sn);
  const selEl    = $('sel_' + sn);
  if (!list || !sh) return;

  // Cột hiển thị trên card (tối đa 4 cột đầu ngoài cột 0)
  const dispCols = sh.headers.slice(0, Math.min(sh.headers.length, 5));

  const frag = document.createDocumentFragment();
  rows.forEach((row, idx) => {
    const div = document.createElement('div');
    div.className  = 'card-item' + (selected.has(idx) ? ' selected' : '');
    div.dataset.idx = idx;

    // Checkbox
    const cb = document.createElement('input');
    cb.type = 'checkbox'; cb.className = 'card-cb';
    cb.checked = selected.has(idx);
    cb.onclick = e => { e.stopPropagation(); toggleSelect(sn, idx, div, cb); };

    // Body
    const body   = document.createElement('div');
    body.className = 'card-body';

    // Title = cột đầu tiên
    const titleEl = document.createElement('div');
    titleEl.className = 'card-title';
    titleEl.innerHTML = hlText(row[0]||'', q);
    body.appendChild(titleEl);

    // Meta = cột 1 → 4
    if (dispCols.length > 1) {
      const meta = document.createElement('div');
      meta.className = 'card-meta';
      dispCols.slice(1).forEach((h, ci) => {
        const val = row[ci+1] || '';
        if (!val) return;
        const tag = document.createElement('span');
        tag.className = 'card-tag';
        tag.innerHTML = `<b>${esc(h)}:</b> ${hlText(val, q)}`;
        meta.appendChild(tag);
      });
      body.appendChild(meta);
    }

    div.appendChild(cb);
    div.appendChild(body);

    // Click → open detail
    div.addEventListener('click', e => {
      if (e.target === cb) return;
      openDetail(sn, idx, row);
    });

    frag.appendChild(div);
  });

  list.innerHTML = '';
  list.appendChild(frag);

  if (infoEl) infoEl.textContent = `${rows.length} / ${sh.rows.length} dòng`;
  updateSelInfo(sn);
}

function toggleSelect(sn, idx, divEl, cbEl) {
  const sel = S.selected[sn];
  if (sel.has(idx)) { sel.delete(idx); divEl.classList.remove('selected'); cbEl.checked=false; }
  else              { sel.add(idx);    divEl.classList.add('selected');    cbEl.checked=true; }
  updateSelInfo(sn);
}

function updateSelInfo(sn) {
  const el = $('sel_' + sn);
  const n  = S.selected[sn]?.size || 0;
  if (el) el.textContent = n > 0 ? `Đã chọn: ${n} dòng` : '';
}

// ============================================================
// DETAIL PANEL
// ============================================================
function openDetail(sn, idx, row) {
  const sh = S.sheets.find(s=>s.sheetName===sn);
  if (!sh) return;
  S.detailRow = { sn, idx };

  const panel  = $('dpanel_' + sn);
  const title  = $('dtitle_' + sn);
  const body   = $('dbody_'  + sn);
  if (!panel) return;

  panel.classList.remove('hidden');
  title.textContent = row[0] || '(không có tên)';

  // Render fields
  let html = '<div>';
  sh.headers.forEach((h, ci) => {
    const val = row[ci] || '';
    html += `
      <div class="detail-row">
        <span class="detail-key">${esc(h)}</span>
        <span class="detail-val ${val?'':'empty'}">${val ? esc(val) : '—'}</span>
        ${val ? `<button class="btn-copy-field" onclick="copyField('${esc(val)}')">copy</button>` : ''}
      </div>`;
  });
  html += '</div>';

  // Preset copy buttons
  const presets = S.presets[sn] || {};
  if (Object.keys(presets).length > 0) {
    html += `<div class="detail-section">
      <div class="detail-section-title">📋 Preset Copy nhanh</div>
      <div class="preset-copy-grid">`;
    Object.entries(presets).forEach(([pn, cols]) => {
      const colPreview = cols.slice(0,3).join('·') + (cols.length>3?'…':'');
      html += `<button class="btn-preset-copy" onclick="copyWithPreset('${sn}',${idx},'${esc(pn)}')">
        <span class="pcn">${esc(pn)}</span>
        <span class="pcc">${esc(colPreview)}</span>
      </button>`;
    });
    html += '</div></div>';
  }

  body.innerHTML = html;

  // Update copy-all label
  const preset = S.activePreset[sn];
  $('dcopyLabel_' + sn).textContent = preset
    ? `Copy dòng này (${preset})`
    : 'Copy dòng này (tất cả cột)';
}

function closeDetail(sn) {
  $('dpanel_' + sn)?.classList.add('hidden');
  S.detailRow = null;
}

function copyField(val) {
  copyText(val);
  toast('✅ Đã copy: ' + val.slice(0,40));
}

function copyDetailRow(sn) {
  if (!S.detailRow || S.detailRow.sn !== sn) return;
  const sh    = S.sheets.find(s=>s.sheetName===sn);
  const row   = S.filtered[sn][S.detailRow.idx];
  if (!sh || !row) return;
  const cols  = getColIndices(sn, S.activePreset[sn]);
  const text  = cols.map(ci => row[ci]||'').join('\t');
  copyText(text);
  toast(`✅ Đã copy 1 dòng`);
}

function copyWithPreset(sn, idx, presetName) {
  const sh   = S.sheets.find(s=>s.sheetName===sn);
  const row  = S.filtered[sn][idx];
  if (!sh || !row) return;
  const cols = getColIndices(sn, presetName);
  const text = cols.map(ci => row[ci]||'').join('\t');
  copyText(text);
  toast(`✅ Đã copy (${presetName})`);
}

// ============================================================
// PRESET CHIPS (search bar area)
// ============================================================
function renderPresetChips(sn) {
  const container = $('pchips_' + sn);
  if (!container) return;
  const presets = S.presets[sn] || {};
  const active  = S.activePreset[sn];
  container.innerHTML = '';

  // "Tất cả cột" chip
  const all = document.createElement('button');
  all.className   = 'preset-chip' + (!active ? ' on' : '');
  all.textContent = 'Tất cả cột';
  all.onclick     = () => setActivePreset(sn, null);
  container.appendChild(all);

  Object.keys(presets).forEach(pn => {
    const c = document.createElement('button');
    c.className = 'preset-chip' + (active===pn?' on':'');
    c.innerHTML = `${esc(pn)}<span class="px" title="Xóa"
      onclick="event.stopPropagation();deletePreset('${sn}','${esc(pn)}')">✕</span>`;
    c.onclick = () => setActivePreset(sn, pn);
    container.appendChild(c);
  });
}

function setActivePreset(sn, pn) {
  S.activePreset[sn] = pn;
  renderPresetChips(sn);
  // Cập nhật nút copy trong detail panel nếu đang mở
  if (S.detailRow?.sn === sn) {
    const el = $('dcopyLabel_' + sn);
    if (el) el.textContent = pn ? `Copy dòng này (${pn})` : 'Copy dòng này (tất cả cột)';
  }
}

// ============================================================
// COPY HELPERS
// ============================================================
function getColIndices(sn, presetName) {
  const sh = S.sheets.find(s=>s.sheetName===sn);
  if (!sh) return [];
  if (presetName && S.presets[sn]?.[presetName]) {
    return S.presets[sn][presetName]
      .map(c => sh.headers.indexOf(c))
      .filter(i => i >= 0);
  }
  return sh.headers.map((_,i)=>i);
}

function copyText(text) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).catch(fallbackCopy.bind(null,text));
  } else { fallbackCopy(text); }
}

function fallbackCopy(text) {
  const ta = document.createElement('textarea');
  ta.value = text; ta.style.cssText='position:fixed;opacity:0';
  document.body.appendChild(ta); ta.select();
  document.execCommand('copy'); document.body.removeChild(ta);
}

function copySelectedRows(sn) {
  const sh  = S.sheets.find(s=>s.sheetName===sn);
  const sel = S.selected[sn];
  const rows = S.filtered[sn];
  if (!sh || !rows) return;

  const target = sel.size > 0
    ? [...sel].sort((a,b)=>a-b).map(i=>rows[i]).filter(Boolean)
    : [];
  if (!target.length) { toast('⚠ Chưa chọn dòng nào. Dùng "Copy tất cả" để copy toàn bộ.'); return; }

  const cols = getColIndices(sn, S.activePreset[sn]);
  const text = target.map(r=>cols.map(ci=>r[ci]||'').join('\t')).join('\n');
  copyText(text);
  const pn = S.activePreset[sn];
  toast(`✅ Đã copy ${target.length} dòng${pn?' — Preset: '+pn:''}`);
}

function copyAll(sn) {
  const sh   = S.sheets.find(s=>s.sheetName===sn);
  const rows = S.filtered[sn];
  if (!sh || !rows?.length) { toast('Không có dữ liệu'); return; }
  const cols = getColIndices(sn, S.activePreset[sn]);
  const text = rows.map(r=>cols.map(ci=>r[ci]||'').join('\t')).join('\n');
  copyText(text);
  const pn = S.activePreset[sn];
  toast(`✅ Đã copy ${rows.length} dòng${pn?' — Preset: '+pn:''}`);
}

// ============================================================
// PRESET MODAL
// ============================================================
function openPresetModal(sn, editName=null) {
  // sn = null → dùng sheet đang chọn trong setup
  const sheetName = sn || $('presetSheetSel').value;
  if (!sheetName) { toast('⚠ Chưa có sheet nào'); return; }
  const sh = S.sheets.find(s=>s.sheetName===sheetName);
  if (!sh) return;

  S._pmSheet = sheetName;
  S._pmEdit  = editName;
  S._pmCols  = editName ? [...(S.presets[sheetName]?.[editName]||[])] : [];

  $('presetModalTitle').textContent = editName ? `Sửa Preset: ${editName}` : 'Thêm Preset mới';
  $('pmName').value = editName || '';

  // Col picker
  const picker = $('pmColPicker');
  picker.innerHTML = sh.headers.map(h=>
    `<button class="cp-chip${S._pmCols.includes(h)?' on':''}"
             data-col="${esc(h)}" onclick="togglePmCol(this,'${esc(h)}')">${esc(h)}</button>`
  ).join('');

  renderPmColOrder();
  $('presetModal').classList.add('open');
}

function closePresetModal() {
  $('presetModal').classList.remove('open');
}

function togglePmCol(el, col) {
  const idx = S._pmCols.indexOf(col);
  if (idx >= 0) { S._pmCols.splice(idx,1); el.classList.remove('on'); }
  else          { S._pmCols.push(col);     el.classList.add('on'); }
  renderPmColOrder();
}

function renderPmColOrder() {
  const el = $('pmColOrder');
  if (!S._pmCols.length) {
    el.innerHTML = '<span style="font-size:11px;color:var(--sub)">Chưa chọn cột nào</span>';
    return;
  }
  el.innerHTML = S._pmCols.map((c,i)=>`
    <span class="co-chip" draggable="true"
          ondragstart="S._dragIdx=${i}"
          ondragover="event.preventDefault()"
          ondrop="pmDrop(event,${i})">
      ${esc(c)}<span class="rx" onclick="removePmCol(${i})">✕</span>
    </span>`).join('');
}

function removePmCol(i) {
  const col = S._pmCols[i];
  S._pmCols.splice(i,1);
  document.querySelectorAll('#pmColPicker .cp-chip').forEach(el=>{
    if(el.dataset.col===col) el.classList.remove('on');
  });
  renderPmColOrder();
}

function pmDrop(e, toIdx) {
  e.preventDefault();
  const from = S._dragIdx;
  if (from===null||from===toIdx) return;
  const item = S._pmCols.splice(from,1)[0];
  S._pmCols.splice(toIdx,0,item);
  S._dragIdx = null;
  renderPmColOrder();
}

function savePreset() {
  const name = $('pmName').value.trim();
  if (!name)            { toast('⚠ Nhập tên preset!'); return; }
  if (!S._pmCols.length){ toast('⚠ Chọn ít nhất 1 cột!'); return; }
  const sn = S._pmSheet;
  if (!S.presets[sn]) S.presets[sn] = {};
  S.presets[sn][name] = [...S._pmCols];
  LS.set('cth_presets', S.presets);
  renderPresetChips(sn);
  renderPresetList();
  closePresetModal();
  toast(`✅ Đã lưu preset "${name}"`);
}

function deletePreset(sn, name) {
  if (!confirm(`Xóa preset "${name}"?`)) return;
  delete S.presets[sn][name];
  if (S.activePreset[sn]===name) S.activePreset[sn]=null;
  LS.set('cth_presets', S.presets);
  renderPresetChips(sn);
  renderPresetList();
  toast(`🗑️ Đã xóa preset "${name}"`);
}

// Preset list in Setup panel
function populatePresetSheetSel() {
  const sel = $('presetSheetSel');
  sel.innerHTML = S.sheets.map(sh=>
    `<option value="${esc(sh.sheetName)}">${esc(sh.sheetName)}</option>`
  ).join('');
}

function renderPresetList() {
  const sn  = $('presetSheetSel').value;
  const con = $('presetListContainer');
  if (!con) return;
  const presets = S.presets[sn] || {};
  const keys    = Object.keys(presets);
  if (!keys.length) {
    con.innerHTML = '<div style="font-size:12px;color:var(--sub);padding:6px 0">Chưa có preset nào.</div>';
    return;
  }
  con.innerHTML = keys.map(pn=>`
    <div class="preset-list-item">
      <span class="pn">${esc(pn)}</span>
      <span class="pc">${presets[pn].join(' · ')}</span>
      <button class="pd" onclick="deletePreset('${esc(sn)}','${esc(pn)}')">Xóa</button>
    </div>`).join('');
}

// ============================================================
// CHANGE PASSWORD
// ============================================================
async function doChangePassword() {
  const oldPass = $('cpwOld').value.trim();
  const newPass = $('cpwNew').value.trim();
  const confirm = $('cpwConfirm').value.trim();
  $('cpwError').textContent = ''; $('cpwOk').textContent = '';

  if (!oldPass||!newPass||!confirm){ $('cpwError').textContent='Nhập đầy đủ thông tin'; return; }
  if (newPass !== confirm)          { $('cpwError').textContent='Mật khẩu mới không khớp'; return; }
  if (newPass.length < 3)           { $('cpwError').textContent='Mật khẩu phải ≥ 3 ký tự'; return; }

  loading(true,'Đang đổi mật khẩu...');
  try {
    const r = await apiCall({
      action:'changePassword', maNV:S.user.maNV, token:S.token,
      oldPass, newPass
    });
    if (r.success) {
      $('cpwOk').textContent = '✅ ' + r.message;
      $('cpwOld').value=''; $('cpwNew').value=''; $('cpwConfirm').value='';
      // Cập nhật remember nếu đang bật
      const saved = LS.get('cth_user');
      if (saved) LS.set('cth_user', { user: S.user, token: S.token });
    } else {
      $('cpwError').textContent = '❌ ' + r.message;
    }
  } catch(e) {
    $('cpwError').textContent = '❌ Lỗi: ' + e.message;
  } finally { loading(false); }
}

// ============================================================
// CACHE INFO
// ============================================================
function updateCacheInfo() {
  const el = $('cacheInfo');
  if (!el) return;
  if (S.fetchedAt) {
    const d = new Date(S.fetchedAt);
    const rows = S.sheets.reduce((s,sh)=>s+sh.rows.length, 0);
    el.innerHTML = `📅 Cập nhật lúc: <b>${d.toLocaleString('vi-VN')}</b><br>
                    📊 Tổng: <b>${S.sheets.length}</b> sheet,
                    <b>${rows.toLocaleString()}</b> dòng dữ liệu`;
  } else {
    el.textContent = 'Chưa có cache';
  }
}

// ============================================================
// KEYBOARD SHORTCUTS
// ============================================================
document.addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    if ($('loginScreen').classList.contains('active'))  doLogin();
    if ($('setupScreen').classList.contains('active'))  saveConfig();
  }
  if (e.key === 'Escape') {
    closePresetModal();
    if (S.detailRow) closeDetail(S.detailRow.sn);
  }
});

// Click outside modal to close
$('presetModal').addEventListener('click', e => {
  if (e.target === $('presetModal')) closePresetModal();
});
</script>
